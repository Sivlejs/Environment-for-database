# Database connection settings
# POSTGRES_HOST is the hostname used by your backend application to connect.
# Within Docker Compose, use "db". Outside Docker, use "localhost".
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=celestial_eye
POSTGRES_USER=celestial_admin
POSTGRES_PASSWORD=change_me_before_use

# Adminer web UI port (accessible at http://localhost:<ADMINER_PORT>)
ADMINER_PORT=8080
